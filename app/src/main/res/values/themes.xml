<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.My_project" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryVariant">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent_teal</item>
        <item name="colorSecondaryVariant">@color/accent_teal</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background / Surface -->
        <item name="android:windowBackground">@color/bg_cream</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/orange_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>